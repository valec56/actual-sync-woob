# ── Woob ──────────────────────────────────────────────────────────────────────
# Bank account identifier as returned by Woob (woob bank accounts)
WOOB_ACCOUNT_ID=

# Number of transactions to fetch (default: 200)
WOOB_HISTORY_COUNT=200

# ── Export ────────────────────────────────────────────────────────────────────
# Name of the OFX file generated in the mounted /data folder (default: bank_export.ofx)
OUTPUT_FILENAME=bank_export.ofx

# ── Schedule ──────────────────────────────────────────────────────────────────
# Cron expression for the automatic trigger (default: every day at 5am)
# Format: minute hour day-of-month month day-of-week
CRON_SCHEDULE=0 5 * * *

# ── v2: Actual Budget API (not used in v1) ────────────────────────────────────
# ACTUAL_SERVER_URL=http://actual:5006
# ACTUAL_PASSWORD=
# ACTUAL_BUDGET_ID=
# ACTUAL_ENCRYPTION_PASSWORD=
# ACTUAL_ACCOUNT_ID=
